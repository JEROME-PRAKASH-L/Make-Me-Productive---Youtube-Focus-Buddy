{
"update_url": "https://clients2.google.com/service/update2/crx",

  "manifest_version": 3,
  "name": "Make Me Productive - YouTube Focus Buddy",
  "version": "2.0",
  "description": "AI-powered YouTube filter: transcript analysis blocks non-educational videos with Gemini AI.",
  "permissions": ["storage", "tabs", "alarms"],
  "host_permissions": [
    "https://generativelanguage.googleapis.com/*"
  ],
  "background": {
    "service_worker": "src/background/index.js"
  },
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "16": "icons/icon.png",
      "48": "icons/icon.png",
      "128": "icons/icon.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["*://www.youtube.com/*"],
      "js": [
        "src/content/keywords.js",
        "src/content/classifier.js",
        "src/content/transcript.js",
        "src/content/ui.js",
        "src/content/stats.js",
        "src/content/watchPage.js",
        "src/content/browsePage.js",
        "src/content/lifecycle.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon.png",
    "48": "icons/icon.png",
    "128": "icons/icon.png"
  }
}
